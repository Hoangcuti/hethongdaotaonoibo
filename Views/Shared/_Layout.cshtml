@using System.Security.Claims
@{
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? Context.Session.GetString("Role") ?? "Employee";
    var fullName = User.FindFirst("FullName")?.Value ?? Context.Session.GetString("FullName") ?? "Nguoi dung";
    var deptName = User.FindFirst("DepartmentName")?.Value ?? Context.Session.GetString("DepartmentName") ?? "No department";
    var deptEmail = User.FindFirst("DepartmentEmail")?.Value ?? "N/A";
    var initialSource = string.IsNullOrWhiteSpace(fullName) ? "ND" : new string(fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => char.ToUpperInvariant(x[0])).ToArray());
    var initials = string.IsNullOrWhiteSpace(initialSource) ? "ND" : initialSource;
    var roleLabel = role switch
    {
        "IT" => "System",
        "Manager" => "Department Lead",
        "HR" => "HR",
        _ => role
    };
}
<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS Corporate</title>
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .swal2-popup { border-radius: 18px !important; font-family: var(--font-text) !important; }
        .swal2-title { font-family: var(--font-display) !important; font-weight: 600 !important; }
        .swal2-styled.swal2-confirm { background-color: var(--color-primary) !important; border-radius: 9999px !important; padding: 10px 22px !important; }
        .swal2-styled.swal2-cancel { border-radius: 9999px !important; }
    </style>
    @RenderSection("Header", required: false)
</head>
<body data-role="@role">
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="setSidebarOpen(false)"></div>

    <div class="dashboard-shell app-shell" data-role="@role">
        <aside class="sidebar" id="appSidebar">
            <div class="sidebar-brand">
                <div class="sidebar-brand-stack">
                    <a href="/" class="sidebar-logo">
                        <span class="sidebar-logo-icon">LMS</span>
                        <span class="sidebar-logo-text">
                            <span class="brand-name">Corporate LMS</span>
                            <span class="brand-sub">@roleLabel workspace</span>
                        </span>
                    </a>
                    <div class="sidebar-user sidebar-user-merged">
                        <span class="sidebar-avatar">@initials</span>
                        <div class="sidebar-user-info">
                            <div class="user-name">@fullName</div>
                            <div class="user-role">@roleLabel</div>
                            <div class="user-meta">@deptName</div>
                            <div class="user-meta">@deptEmail</div>
                        </div>
                    </div>
                </div>
            </div>

            <nav class="sidebar-nav" aria-label="Sidebar navigation">
                <div class="nav-section-label">Overview</div>
                <ul>
                    <li class="nav-item">
                        <a class="nav-link active" onclick="location.href='@Url.Action("Index", role == "IT" ? "IT" : "HR")'">
                            <span class="nav-icon">⌂</span>
                            <span class="nav-text">Dashboard</span>
                        </a>
                    </li>
                </ul>

                @if (role == "Manager" || role == "Trainer" || role == "Lecturer")
                {
                    <div class="nav-section-label">Department</div>
                    <ul>
                        @if (role == "Manager")
                        {
                            <li class="nav-item"><a class="nav-link" onclick="navigate('members')"><span class="nav-icon">◉</span><span class="nav-text">Nhan vien</span></a></li>
                        }
                        <li class="nav-item"><a class="nav-link" onclick="navigate('courses')"><span class="nav-icon">▤</span><span class="nav-text">Khoa hoc</span></a></li>
                        <li class="nav-item"><a class="nav-link" onclick="navigate('exams')"><span class="nav-icon">📝</span><span class="nav-text">Bai thi</span></a></li>
                        @if (role == "Manager")
                        {
                            <li class="nav-item"><a class="nav-link" onclick="navigate('assignments')"><span class="nav-icon">↗</span><span class="nav-text">Phan cong</span></a></li>
                            <li class="nav-item"><a class="nav-link" onclick="navigate('staff-progress')"><span class="nav-icon">◔</span><span class="nav-text">Tien do</span></a></li>
                            <li class="nav-item"><a class="nav-link" onclick="navigate('hr-notifications')"><span class="nav-icon">&#128276;</span><span class="nav-text">Thong bao</span></a></li>
                        }
                        <li class="nav-item"><a class="nav-link" onclick="navigate('documents')"><span class="nav-icon">≣</span><span class="nav-text">Tai lieu</span></a></li>
                    </ul>
                }

                @if (role == "IT")
                {
                    <div class="nav-section-label">Admin</div>
                    <ul>
                        <li class="nav-item"><a class="nav-link" data-permission="users.manage" data-nav-page="users" onclick="navigate('users')"><span class="nav-icon">◉</span><span class="nav-text">Nguoi dung</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="departments.manage" data-nav-page="departments" onclick="navigate('departments')"><span class="nav-icon">⌘</span><span class="nav-text">Phong ban</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="courses.manage" data-nav-page="courses" onclick="navigate('courses')"><span class="nav-icon">▤</span><span class="nav-text">Khoa hoc</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="courses.manage" data-nav-page="exams" onclick="navigate('exams')"><span class="nav-icon">📝</span><span class="nav-text">Bai thi</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="categories.manage" data-nav-page="categories" onclick="navigate('categories')"><span class="nav-icon">◇</span><span class="nav-text">Danh muc</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="faqs.manage" data-nav-page="faqs" onclick="navigate('faqs')"><span class="nav-icon">?</span><span class="nav-text">FAQ</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="content.documents.manage" data-nav-page="documents" onclick="navigate('documents')"><span class="nav-icon">≣</span><span class="nav-text">Tai lieu</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-nav-page="approvals" onclick="navigate('approvals')"><span class="nav-icon">✓</span><span class="nav-text">Phe duyet</span></a></li>
                    </ul>

                    <div class="nav-section-label">Operations</div>
                    <ul>
                        <li class="nav-item"><a class="nav-link" data-permission="analytics.view" data-nav-page="analytics" onclick="navigate('analytics')"><span class="nav-icon">◔</span><span class="nav-text">Phan tich</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="auditlogs.view" data-nav-page="auditlogs" onclick="navigate('auditlogs')"><span class="nav-icon">☰</span><span class="nav-text">Audit logs</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="backup.manage" data-nav-page="backup" onclick="navigate('backup')"><span class="nav-icon">⎘</span><span class="nav-text">Backup</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="newsletter.manage" data-nav-page="newsletter" onclick="navigate('newsletter')"><span class="nav-icon">✦</span><span class="nav-text">Notifications</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="settings.manage" data-nav-page="settings" onclick="navigate('settings')"><span class="nav-icon">⚙</span><span class="nav-text">Settings</span></a></li>
                    </ul>

                    <div class="nav-section-label">Future Roles</div>
                    <ul>
                        <li class="nav-item"><a class="nav-link" onclick="navigate('permissions')"><span class="nav-icon">✦</span><span class="nav-text">Admin hub</span></a></li>
                        <li class="nav-item"><a class="nav-link" onclick="navigate('courses')"><span class="nav-icon">✎</span><span class="nav-text">Instructor flow</span></a></li>
                        <li class="nav-item"><a class="nav-link" onclick="navigate('backup')"><span class="nav-icon">⚙</span><span class="nav-text">System center</span></a></li>
                    </ul>
                }

                <div class="nav-section-label">Account</div>
                <ul>
                    <li class="nav-item">
                        <a class="nav-link" href="/Auth/Logout">
                            <span class="nav-icon">↩</span>
                            <span class="nav-text">Dang xuat</span>
                        </a>
                    </li>
                </ul>

                <div class="nav-section-label">Preferences</div>
                <ul>
                    <li class="nav-item">
                        <button id="themeToggleBtn" type="button" class="nav-link" onclick="toggleTheme()">
                            <span class="nav-icon">☀</span>
                            <span class="nav-text">Theme</span>
                        </button>
                    </li>
                </ul>
            </nav>

        </aside>

        <main class="main-content">
            <header class="app-topbar">
                <div class="topbar-title-group">
                    <div class="topbar-overline">Internal learning platform</div>
                    <div class="page-title">@ViewData["Title"]</div>
                    <div class="page-subtitle">@deptName</div>
                </div>
                <div class="topbar-actions">
                    <button type="button" class="btn btn-secondary btn-icon topbar-menu-trigger mobile-only" aria-label="Open navigation" onclick="setSidebarOpen(true)">☰</button>
                    <button type="button" class="btn btn-secondary btn-icon mobile-only" aria-label="Notifications">🔔</button>
                    <div class="topbar-user">
                        <span class="topbar-avatar">@initials</span>
                        <div class="topbar-user-copy">
                            <span class="topbar-user-name">@fullName</span>
                            <span class="topbar-user-role">@roleLabel</span>
                        </div>
                    </div>
                </div>
            </header>

            @RenderBody()
        </main>
    </div>

    @RenderSection("Modals", required: false)

    <script src="~/js/app.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initializeTheme();
            initializeShell();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
