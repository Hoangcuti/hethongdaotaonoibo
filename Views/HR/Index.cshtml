@{
    ViewData["Title"] = "Quản lý Phòng ban";
    Layout = "_Layout";
}

@section Header {
    <meta name="description" content="Giao diện quản lý phòng ban - nhân viên, khóa học và đào tạo nội bộ" />
    <style>
        /* ===== ENTERPRISE MANAGER DASHBOARD STYLES ===== */
        .mgr-kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
        .mgr-kpi { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px; position: relative; overflow: hidden; transition: transform .2s, box-shadow .2s; }
        .mgr-kpi:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.3); }
        .mgr-kpi-accent { position: absolute; top: 0; left: 0; width: 4px; height: 100%; border-radius: 12px 0 0 12px; }
        .mgr-kpi-icon { font-size: 28px; margin-bottom: 8px; }
        .mgr-kpi-value { font-size: 28px; font-weight: 800; line-height: 1; margin-bottom: 4px; }
        .mgr-kpi-label { font-size: 14px; color: var(--text-secondary); font-weight: 500; text-transform: uppercase; letter-spacing: .5px; }
        .mgr-kpi-change { font-size: 13px; margin-top: 6px; }

        /* Employee Cards Grid */
        .emp-search-bar { display: flex; gap: 10px; margin-bottom: 20px; align-items: center; flex-wrap: wrap; }
        .emp-search-input { flex: 1; min-width: 200px; background: var(--input-bg); border: 1px solid var(--border-color); color: var(--text-primary); border-radius: 8px; padding: 12px 16px; font-size: 16px; outline: none; transition: border-color .2s; }
        .emp-search-input:focus { border-color: var(--primary); }
        .emp-filter-btn { padding: 10px 16px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--card-bg); color: var(--text-primary); font-size: 15px; cursor: pointer; transition: all .2s; }
        .emp-filter-btn.active, .emp-filter-btn:hover { background: var(--primary); border-color: var(--primary); color: #fff; }

        .emp-cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
        .emp-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px; cursor: pointer; transition: all .2s; position: relative; }
        .emp-card:hover { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(59,130,246,.1); transform: translateY(-1px); }
        .emp-card-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
        .emp-avatar { width: 56px; height: 56px; border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 700; flex-shrink: 0; }
        .emp-card-name { font-weight: 600; font-size: 17px; line-height: 1.2; }
        .emp-card-sub { font-size: 14px; color: var(--text-secondary); margin-top: 2px; }
        .emp-card-badge { position: absolute; top: 14px; right: 14px; }
        .emp-progress-wrap { margin-bottom: 12px; }
        .emp-progress-label { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 5px; }
        .emp-progress-bar { height: 6px; background: var(--border-color); border-radius: 3px; overflow: hidden; }
        .emp-progress-fill { height: 100%; border-radius: 3px; transition: width 1s ease; }
        .emp-card-actions { display: flex; gap: 8px; margin-top: 14px; }
        .emp-card-actions .btn { flex: 1; font-size: 12px; padding: 7px; justify-content: center; }

        /* Status badges */
        .badge-status-active { background: rgba(16,185,129,.15); color: #10b981; border-radius: 20px; padding: 3px 10px; font-size: 11px; font-weight: 600; }
        .badge-status-inactive { background: rgba(148,163,184,.15); color: #94a3b8; border-radius: 20px; padding: 3px 10px; font-size: 11px; font-weight: 600; }

        /* Course cards */
        .course-list-item { display: flex; align-items: center; gap: 14px; padding: 14px; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 10px; margin-bottom: 10px; transition: border-color .2s; }
        .course-list-item:hover { border-color: var(--primary); }
        .course-icon-box { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
        .course-list-info { flex: 1; }
        .course-list-title { font-weight: 600; font-size: 14px; }
        .course-list-meta { font-size: 12px; color: var(--text-secondary); margin-top: 3px; }

        /* Assignment timeline */
        .assign-item { display: flex; gap: 14px; padding: 14px 0; border-bottom: 1px solid var(--border-color); }
        .assign-item:last-child { border-bottom: none; }
        .assign-avatar-sm { width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px; color: #fff; }
        .assign-info { flex: 1; }
        .assign-name { font-weight: 600; font-size: 13px; }
        .assign-course { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
        .priority-high { background: rgba(239,68,68,.15); color: #ef4444; border-radius: 4px; padding: 2px 7px; font-size: 11px; font-weight: 600; }
        .priority-normal { background: rgba(59,130,246,.15); color: #3b82f6; border-radius: 4px; padding: 2px 7px; font-size: 11px; font-weight: 600; }
        .priority-low { background: rgba(16,185,129,.15); color: #10b981; border-radius: 4px; padding: 2px 7px; font-size: 11px; font-weight: 600; }

        /* Profile Panel */
        #profileOverlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); backdrop-filter: blur(3px); z-index: 300; display: none; }
        #profilePanel { position: fixed; top: 0; right: -500px; width: 480px; height: 100vh; background: var(--bg-secondary); border-left: 1px solid var(--border-color); box-shadow: -20px 0 60px rgba(0,0,0,.5); z-index: 301; transition: right .35s cubic-bezier(.4,0,.2,1); display: flex; flex-direction: column; overflow-y: auto; }
        .profile-hero { background: linear-gradient(135deg, #1e1b4b 0%, #172554 100%); padding: 30px 24px 20px; border-bottom: 1px solid var(--border-color); }
        .profile-avatar-lg { width: 72px; height: 72px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px; font-weight: 700; color: #fff; margin-bottom: 14px; border: 3px solid rgba(255,255,255,.2); }
        .profile-name-lg { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
        .profile-meta { font-size: 13px; color: #94a3b8; }
        .profile-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
        .profile-tag { background: rgba(255,255,255,.1); color: #e2e8f0; border-radius: 20px; padding: 4px 12px; font-size: 11px; font-weight: 500; }
        .profile-body { padding: 20px 24px; flex: 1; }
        .profile-section { margin-bottom: 24px; }
        .profile-section-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
        .course-row { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px; margin-bottom: 8px; }
        .skill-bar-row { margin-bottom: 10px; }
        .skill-bar-label { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 5px; }
        .skill-bar-bg { height: 8px; background: var(--border-color); border-radius: 4px; overflow: hidden; }
        .skill-bar-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, #3b82f6, #8b5cf6); }

        /* Quick stats strip in profile */
        .profile-stats-strip { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 20px; }
        .profile-stat-box { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px; text-align: center; }
        .profile-stat-num { font-size: 20px; font-weight: 700; }
        .profile-stat-lbl { font-size: 11px; color: var(--text-secondary); margin-top: 2px; }

        /* Charts section */
        .charts-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
        @@media (max-width: 900px) { .charts-2col { grid-template-columns: 1fr; } .mgr-kpi-grid { grid-template-columns: repeat(2, 1fr); } .emp-cards-grid { grid-template-columns: 1fr; } }
    </style>
}

<div class="page-header">
    <div>
        <div class="page-title" id="pageTitle">Tổng quan bộ phận</div>
        <div class="page-subtitle" id="pageSubtitle">Dashboard quản lý nhân sự và đào tạo</div>
    </div>
    <div class="header-actions">
        @if (Context.Session.GetString("DepartmentName") == "Trung tâm Đào tạo Nội bộ")
        {
            <button class="btn btn-secondary" id="btnBroadcast" onclick="navigate('courses'); openAssignDeptModal();">
                📢 Phân khóa học cho phòng ban
            </button>
        }
        else
        {
            <button class="btn btn-secondary" id="btnBroadcast" onclick="navigate('courses'); openAssignDeptModal();">
                📢 Giao toàn phòng
            </button>
        }
        <button class="btn btn-primary" onclick="openCreateEmployeeModal()">
            ➕ Thêm nhân sự
        </button>
    </div>
</div>

<div class="content-area">

    <!-- ======= PAGE: OVERVIEW ======= -->
    <div id="hr-overview" class="page-section fade-in">
        <!-- KPI Cards -->
        <div class="mgr-kpi-grid" id="kpiGrid">
            <div class="mgr-kpi"><div class="mgr-kpi-accent" style="background:#3b82f6"></div><div class="mgr-kpi-icon">👥</div><div class="mgr-kpi-value" id="kpiEmp">—</div><div class="mgr-kpi-label">Nhân sự hiện có</div></div>
            <div class="mgr-kpi"><div class="mgr-kpi-accent" style="background:#10b981"></div><div class="mgr-kpi-icon">✅</div><div class="mgr-kpi-value" id="kpiCompleted">—</div><div class="mgr-kpi-label">Khóa đã hoàn thành</div></div>
            <div class="mgr-kpi"><div class="mgr-kpi-accent" style="background:#f59e0b"></div><div class="mgr-kpi-icon">📋</div><div class="mgr-kpi-value" id="kpiAssigned">—</div><div class="mgr-kpi-label">Nhiệm vụ đang giao</div></div>
            <div class="mgr-kpi"><div class="mgr-kpi-accent" style="background:#8b5cf6"></div><div class="mgr-kpi-icon">🏅</div><div class="mgr-kpi-value" id="kpiCerts">—</div><div class="mgr-kpi-label">Chứng chỉ đạt được</div></div>
        </div>

        <!-- Charts -->
        <div class="charts-2col">
            <div class="card">
                <div class="card-header"><div class="card-title">📊 Tiến độ đào tạo theo trạng thái</div></div>
                <div class="card-body"><canvas id="progressChart" height="180"></canvas></div>
            </div>
            <div class="card">
                <div class="card-header"><div class="card-title">💰 Ngân sách đào tạo</div></div>
                <div class="card-body" style="display:flex;align-items:center;justify-content:center;gap:24px;height:200px;">
                    <div style="width:150px;height:150px;position:relative;">
                        <canvas id="budgetChart"></canvas>
                    </div>
                    <div id="budgetLegend" style="font-size:13px;"></div>
                </div>
            </div>
        </div>

        <!-- Top employees at-risk (not started) -->
        <div class="card">
            <div class="card-header">
                <div class="card-title">⚠️ Nhân viên chưa bắt đầu đào tạo</div>
                <button class="btn btn-sm btn-secondary" onclick="navigate('members')">Xem tất cả →</button>
            </div>
            <div id="atRiskList" class="card-body" style="padding:10px 16px;">
                <div class="loading-overlay"><div class="spinner"></div></div>
            </div>
        </div>
    </div>

    <!-- ======= PAGE: MEMBERS ======= -->
    <div id="members" class="page-section" style="display:none">
        <div class="emp-search-bar">
            <input class="emp-search-input" id="empSearch" type="text" placeholder="🔍  Tìm theo tên, mã NV, email..." oninput="filterEmployees()">
            <button class="emp-filter-btn active" id="fAll" onclick="setFilter('all')">Tất cả</button>
            <button class="emp-filter-btn" id="fActive" onclick="setFilter('active')">✅ Đang làm</button>
            <button class="emp-filter-btn" id="fInactive" onclick="setFilter('inactive')">⛔ Vô hiệu</button>
            <button class="btn btn-primary btn-sm" onclick="openCreateEmployeeModal()">➕ Thêm nhân sự</button>
        </div>
        <div id="empCountLabel" style="font-size:13px; color:var(--text-secondary); margin-bottom:12px;"></div>
        <div class="emp-cards-grid" id="empCardsGrid">
            <div style="grid-column:1/-1; text-align:center; padding:40px;"><div class="spinner"></div></div>
        </div>
    </div>

    <!-- ======= PAGE: COURSES ======= -->
    <div id="courses" class="page-section" style="display:none">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <div style="font-size:14px; color:var(--text-secondary);" id="courseCountLabel">Đang tải...</div>
            <div style="display:flex;gap:10px;">
                @if (Context.Session.GetString("DepartmentName") == "Trung tâm Đào tạo Nội bộ")
                {
                    <button class="btn btn-secondary" onclick="openAssignDeptModal()">📢 Phân khóa học cho phòng ban</button>
                }
                else
                {
                    <button class="btn btn-secondary" onclick="openAssignDeptModal()">📢 Giao toàn phòng</button>
                }
                <button class="btn btn-primary" onclick="openCreateCourseModal()">✨ Tạo khóa học AI</button>
            </div>
        </div>
        <div id="courseListContainer">
            <div class="loading-overlay"><div class="spinner"></div></div>
        </div>
    </div>

    <!-- ======= PAGE: ASSIGNMENTS ======= -->
    <div id="assignments" class="page-section" style="display:none">
        <div class="card">
            <div class="card-header">
                <div class="card-title">🎯 Lịch sử phân công đào tạo</div>
                <button class="btn btn-sm btn-primary" onclick="openAssignModal()">➕ Tạo phân công</button>
            </div>
            <div class="card-body" style="padding: 0 4px;" id="assignmentListContainer">
                <div class="loading-overlay"><div class="spinner"></div></div>
            </div>
        </div>
    </div>

    <!-- ======= PAGE: STAFF PROGRESS ======= -->
    <div id="staff-progress" class="page-section" style="display:none">
        <div class="card">
            <div class="card-header">
                <div class="card-title">📈 Theo dõi tiến độ chi tiết</div>
                <div class="card-subtitle">Thống kê các bài quiz chưa hoàn thành và bài học còn thiếu.</div>
            </div>
            <div class="card-body">
                <div class="table-wrapper">
                    <table class="lms-table">
                        <thead>
                            <tr>
                                <th>Nhân viên</th>
                                <th>Bài Quiz chưa xong</th>
                                <th>Bài học còn thiếu</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="staffProgressTable">
                            <tr><td colspan="4"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- ======= PAGE: HR NOTIFICATIONS ======= -->
    <div id="hr-notifications" class="page-section" style="display:none">
        <div class="card">
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <div class="card-title">🔔 Danh sách thông báo đề xuất</div>
                    <div class="card-subtitle">Xem các đề xuất xin gia hạn khóa học và thông báo từ nhân viên.</div>
                </div>
                <div>
                    <button class="btn btn-secondary btn-sm" onclick="markAllHrNotificationsRead()">Đọc tất cả</button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-wrapper">
                    <table class="lms-table">
                        <thead>
                            <tr>
                                <th>Tiêu đề / Nội dung</th>
                                <th>Trạng thái</th>
                                <th style="width:200px; text-align:center;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="hrNotificationsTable">
                            <tr><td colspan="3"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- ======= PAGE: ATTENDANCE ======= -->
    <div id="attendance" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-header">
                <div class="card-title">📅 Quản lý điểm danh</div>
                <div class="card-subtitle">Điểm danh cho các buổi học offline của bộ phận.</div>
            </div>
            <div class="card-body" style="display:flex; gap:12px;">
                <select id="attendanceEventSelect" class="form-input" style="flex:1" onchange="loadAttendanceList()"></select>
                <button class="btn btn-primary" onclick="loadAttendanceList()">🔄 Tải lại</button>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>Nhân viên</th>
                            <th>Thời gian</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="attendanceTable">
                        <tr><td colspan="4" style="text-align:center; padding:40px; color:#64748b;">Chọn một sự kiện để xem danh sách điểm danh.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ======= PAGE: DOCUMENTS ======= -->
    <div id="documents" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <div class="card-title">🗂️ Kho tài liệu bộ phận</div>
                    <div class="card-subtitle">Tải lên và quản lý tài liệu đào tạo của phòng ban.</div>
                </div>
                <button class="btn btn-primary" onclick="openUploadDocModal()">📤 Tải lên tài liệu</button>
            </div>
            <div class="card-body" style="padding: 14px 20px; border-top: 1px solid #e2e8f0;">
                <div style="display:flex; gap:12px; flex-wrap:wrap; align-items:center">
                    <div class="input-wrap" style="flex:1; min-width:200px">
                        <span class="input-icon">🔍</span>
                        <input id="docSearch" type="text" class="form-input with-icon" placeholder="Tìm tên tài liệu hoặc khóa học..." oninput="filterDeptDocuments()">
                    </div>
                    <select id="docTypeFilter" class="form-input" style="width:180px" onchange="filterDeptDocuments()">
                        <option value="">Tất cả loại</option>
                        <option value="Quiz">Quiz</option>
                        <option value="Bài giảng">Bài giảng</option>
                        <option value="Chương">Chương</option>
                        <option value="Tài liệu">Tài liệu độc lập</option>
                    </select>
                    <select id="docStatusFilter" class="form-input" style="width:180px" onchange="filterDeptDocuments()">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Pending">Chờ duyệt</option>
                        <option value="Approved">Đã duyệt</option>
                        <option value="Rejected">Từ chối</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>Tên tài liệu</th>
                            <th>Loại nội dung</th>
                            <th>Trạng thái phê duyệt</th>
                            <th>Đường dẫn</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="deptDocsTable">
                        <tr><td colspan="4" style="text-align:center; padding:40px; color:#64748b;">Đang tải dữ liệu...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ======= PAGE: EXAMS ======= -->
    <div id="exams" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-header" style="border-bottom:none; padding-bottom:6px; display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <div class="card-title">📝 Quản lý bài kiểm tra & Đánh giá</div>
                    <div class="card-subtitle">Theo dõi thống kê Đạt / Không đạt và thiết lập cấu trúc đề thi kéo thả.</div>
                </div>
                <button class="btn btn-primary" onclick="openCreateExamModal()">➕ Tạo bài thi mới</button>
            </div>
        </div>

        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px">
                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
                    <div class="input-wrap" style="flex:1;min-width:240px">
                        <span class="input-icon">🔍</span>
                        <input id="examsSearch" type="text" class="form-input with-icon" placeholder="Tìm theo tên bài thi hoặc khóa học..." oninput="renderExamsPageList()">
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th style="width:50px">ID</th>
                            <th>Tên bài thi</th>
                            <th>Khóa học</th>
                            <th>Số câu hỏi</th>
                            <th>Thời gian</th>
                            <th>Điểm qua</th>
                            <th>Đạt</th>
                            <th>Không đạt</th>
                            <th style="text-align:right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="examsTableBody">
                        <tr><td colspan="9"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>


@section Modals {
<!-- ========== MODALS ========== -->


<!-- Exam Builder Modal -->
<div class="modal-backdrop" id="examBuilderModal">
    <div class="modal-box" style="max-width:1440px; width:98vw; height:95vh; display:flex; flex-direction:column; overflow:hidden;">
        <div class="modal-header">
            <div>
