@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const userRole = '@Context.Session.GetString("Role")';
const currentUserId = parseInt('@Context.Session.GetString("UserID")');
const isTrainingCenter = @(Context.Session.GetString("DepartmentName") == "Trung tâm Đào tạo Nội bộ" ? "true" : "false");
let employees = [], courses = [], charts = {}, currentFilter = 'all', currentProfileId = null, hrCourseContent = null, hrSelectedModuleId = null;
const AVATAR_COLORS = ['#3b82f6','#8b5cf6','#10b981','#f59e0b','#ef4444','#06b6d4','#ec4899'];

function avatarColor(name) { let h = 0; for(let c of name) h += c.charCodeAt(0); return AVATAR_COLORS[h % AVATAR_COLORS.length]; }

function libraryEscape(value) {
    if (value == null) return '';
    return String(value).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

async function loadDepartments() {
    if (!isTrainingCenter) return;
    try {
        const depts = await apiFetch('/api/hr/departments');
        const select = document.getElementById('assignDeptSelect');
        if (select) {
            select.innerHTML = '<option value="">-- Chọn phòng ban --</option>' + 
                depts.map(d => `<option value="${d.departmentId}">${d.departmentName}</option>`).join('');
        }
    } catch(e) {
        console.error('Lỗi tải danh sách phòng ban:', e);
    }
}

async function init() {
    document.addEventListener('themechanged', () => {
        const overviewEl = document.getElementById('hr-overview');
        if (overviewEl && overviewEl.style.display !== 'none') {
            loadOverview();
        }
    });

    if (userRole === 'Trainer' || userRole === 'Lecturer') {
        await loadCourses();
        navigate('courses');
    } else {
        await Promise.all([loadOverview(), loadEmployeesData(), loadCourses(), loadAssignmentsData(), loadDepartments()]);
        navigate('hr-overview');
    }
}

async function loadOverview() {
    try {
        const s = await apiFetch('/api/hr/stats');
        window.currentDeptPrefix = s.deptPrefix || 'HR';
        document.getElementById('kpiEmp').textContent = s.totalEmployees;
        document.getElementById('kpiCompleted').textContent = s.completedTrainings;
        document.getElementById('kpiAssigned').textContent = s.totalAssignments;
        document.getElementById('kpiCerts').textContent = s.totalCertificates;
        renderCharts(s);
    } catch(e) {}
}

function renderCharts(s) {
    const style = getComputedStyle(document.documentElement);
    const successColor = style.getPropertyValue('--color-success').trim() || '#10b981';
    const primaryColor = style.getPropertyValue('--color-primary').trim() || '#3b82f6';
    const textSecondary = style.getPropertyValue('--color-text-secondary').trim() || '#94a3b8';
    const textColor = style.getPropertyValue('--color-text').trim() || '#1d1d1f';
    const surfaceSubtle = style.getPropertyValue('--color-surface-subtle').trim() || '#f0f0f3';
    const infoColor = style.getPropertyValue('--color-info').trim() || '#2454cc';

    const pCtx = document.getElementById('progressChart').getContext('2d');
    if(charts.p) charts.p.destroy();
    charts.p = new Chart(pCtx, {
        type:'doughnut',
        data:{ labels:['Hoàn thành','Đang học','Chưa bắt đầu'], datasets:[{ data:[s.completedTrainings||0, Math.max(0,(s.totalAssignments||0)-(s.completedTrainings||0)), 2], backgroundColor:[successColor,primaryColor,textSecondary], borderWidth:0 }] },
        options:{ 
            plugins:{ 
                legend:{ 
                    position:'right', 
                    labels:{ color:textColor, font:{ family: 'var(--font-text)', size:12 } } 
                } 
            }, 
            cutout:'70%',
            responsive: true,
            maintainAspectRatio: false
        }
    });

    const bCtx = document.getElementById('budgetChart').getContext('2d');
    if(charts.b) charts.b.destroy();
    const spent = s.spentBudget || 0, total = s.totalBudget || 1;
    charts.b = new Chart(bCtx, {
        type:'doughnut',
        data:{ labels:['Đã chi','Còn lại'], datasets:[{ data:[spent, Math.max(0,total-spent)], backgroundColor:[infoColor,surfaceSubtle], borderWidth:0 }] },
        options:{ maintainAspectRatio:true, responsive:true, plugins:{ legend:{ display:false } }, cutout:'72%' }
    });
    document.getElementById('budgetLegend').innerHTML = `
        <div style="margin-bottom:8px;"><div style="font-size:11px;color:var(--color-text-secondary);">Đã chi</div><div style="font-weight:700;color:var(--color-info)">${fmtMoney(spent)}</div></div>
        <div><div style="font-size:11px;color:var(--color-text-secondary);">Tổng NS</div><div style="font-weight:700;color:var(--color-text);">${fmtMoney(total)}</div></div>
        <div style="margin-top:8px;"><div style="font-size:11px;color:var(--color-text-secondary);">Đã dùng</div><div style="font-weight:700;color:${s.budgetUsagePercent>80?'var(--color-danger)':'var(--color-success)'}">${s.budgetUsagePercent}%</div></div>`;
}
function fmtMoney(v) { if(v>=1e9) return (v/1e9).toFixed(1)+'B'; if(v>=1e6) return (v/1e6).toFixed(1)+'M'; return v.toLocaleString(); }

function openCreateEmployeeModal() {
    const codeEl = document.getElementById('newEmpCode');
    const nameEl = document.getElementById('newEmpName');
    const emailEl = document.getElementById('newEmpEmail');
    
    if (nameEl) nameEl.value = '';
    if (emailEl) emailEl.value = '';
    
    if (codeEl) {
        const prefix = window.currentDeptPrefix || 'HR';
        codeEl.value = prefix + String(Math.floor(1000 + Math.random() * 9000));
    }
    openModal('createEmployeeModal');
}

async function loadEmployeesData() {
    try {
        employees = await apiFetch('/api/hr/employees');
        const sel = document.getElementById('assignEmployee');
        if(sel) sel.innerHTML = '<option value="">-- Chọn nhân viên --</option>' + employees.filter(e=>e.status==='Active' && e.userId !== currentUserId).map(e=>`<option value="${e.userId}">${e.fullName}</option>`).join('');
        renderEmpCards();
        renderAtRisk();
    } catch(e) {}
}

function renderAtRisk() {
    const atRisk = employees.filter(e => e.status==='Active' && e.assignedCount === 0).slice(0, 5);
    const el = document.getElementById('atRiskList');
    if(!el) return;
    if(atRisk.length === 0) { el.innerHTML = '<div style="text-align:center;color:var(--text-secondary);padding:20px;">🎉 Tất cả nhân viên đã được giao đào tạo!</div>'; return; }
    el.innerHTML = atRisk.map(e=>`
        <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border-color);">
            <div style="width:36px;height:36px;border-radius:50%;background:${avatarColor(e.fullName)};color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;">${e.fullName.charAt(0)}</div>
            <div style="flex:1;"><div style="font-weight:600;font-size:14px;">${e.fullName}</div><div style="font-size:12px;color:var(--text-secondary);">${e.email}</div></div>
            <button class="btn btn-sm btn-primary" onclick="openAssignModal(null,${e.userId})">🎯 Giao việc</button>
        </div>`).join('');
}

function setFilter(f) {
    currentFilter = f;
    ['fAll','fActive','fInactive'].forEach(id=>document.getElementById(id).classList.remove('active'));
    document.getElementById(f==='all'?'fAll':f==='active'?'fActive':'fInactive').classList.add('active');
    renderEmpCards();
}

function filterEmployees() { renderEmpCards(); }

function renderEmpCards() {
    const q = (document.getElementById('empSearch')?.value||'').toLowerCase();
    let list = employees.filter(e=>{
        const matchFilter = currentFilter==='all' || (currentFilter==='active'&&e.status==='Active') || (currentFilter==='inactive'&&e.status!=='Active');
        const matchQ = !q || e.fullName.toLowerCase().includes(q) || (e.employeeCode||'').toLowerCase().includes(q) || (e.email||'').toLowerCase().includes(q);
        return matchFilter && matchQ;
    });
    const lbl = document.getElementById('empCountLabel');
    if(lbl) lbl.textContent = `Hiển thị ${list.length} / ${employees.length} nhân viên`;
    const grid = document.getElementById('empCardsGrid');
    if(!grid) return;
    if(list.length===0){ grid.innerHTML='<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--text-secondary);">Không tìm thấy nhân viên phù hợp</div>'; return; }
    grid.innerHTML = list.map(e=>{
        const pct = e.assignedCount>0 ? Math.round(e.completedCount/e.assignedCount*100) : 0;
        const col = avatarColor(e.fullName);
        const isActive = e.status === 'Active';
        const pctColor = pct===100?'#10b981':pct>50?'#3b82f6':'#f59e0b';
        return `<div class="emp-card" onclick="openEmployeeProfile(${e.userId})">
            <div class="emp-card-badge"><span class="${isActive?'badge-status-active':'badge-status-inactive'}">${isActive?'Đang làm':'Vô hiệu'}</span></div>
            <div class="emp-card-header">
                <div class="emp-avatar" style="background:${col};">${e.fullName.charAt(0).toUpperCase()}</div>
                <div>
                    <div class="emp-card-name">${e.fullName}</div>
                    <div class="emp-card-sub">${e.employeeCode ? e.employeeCode : ''}</div>
                    <div class="emp-card-sub" style="margin-top:2px;">${e.email||''}</div>
                </div>
            </div>
            <div class="emp-progress-wrap">
                <div class="emp-progress-label">
                    <span style="color:var(--text-secondary);">Tiến độ đào tạo</span>
                    <span style="font-weight:700;color:${pctColor};">${pct}%</span>
                </div>
                <div class="emp-progress-bar"><div class="emp-progress-fill" style="width:${pct}%;background:${pctColor};"></div></div>
                <div style="font-size:11px;color:var(--text-secondary);margin-top:4px;">${e.completedCount}/${e.assignedCount} khóa hoàn thành</div>
            </div>
            <div class="emp-card-actions" onclick="event.stopPropagation()">
                <button class="btn btn-secondary btn-sm" onclick="openEmployeeProfile(${e.userId})">👤 Hồ sơ</button>
                <button class="btn btn-primary btn-sm" onclick="openAssignModal(null,${e.userId})">🎯 Giao việc</button>
            </div>
        </div>`;
    }).join('');
}

async function loadCourses() {
    try {
        courses = await apiFetch('/api/hr/courses');
        const opts = courses.map(c=>`<option value="${c.courseId}">${c.title}</option>`).join('');
        ['assignCourse','assignDeptCourse'].forEach(id=>{ const el=document.getElementById(id); if(el) el.innerHTML='<option value="">-- Chọn khóa học --</option>'+opts; });
        const lbl = document.getElementById('courseCountLabel');
        if(lbl) lbl.textContent = `${courses.length} khóa học trong phòng`;
        const container = document.getElementById('courseListContainer');
        if(!container) return;
        if(courses.length===0){ container.innerHTML='<div style="text-align:center;padding:60px;color:var(--text-secondary);">Chưa có khóa học nào. Hãy tạo khóa học đầu tiên bằng AI!</div>'; return; }
        container.innerHTML = courses.map(c=>{
            const isOwned = c.isOwned, isMandatory = c.isMandatory;
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const bgHeader = isOwned 
                ? (isDark ? 'linear-gradient(135deg, hsl(225, 40%, 20%) 0%, hsl(225, 30%, 15%) 100%)' : 'linear-gradient(135deg, hsl(225, 75%, 94%) 0%, hsl(225, 60%, 88%) 100%)')
                : (isDark ? 'linear-gradient(135deg, hsl(160, 40%, 18%) 0%, hsl(160, 30%, 14%) 100%)' : 'linear-gradient(135deg, hsl(160, 75%, 94%) 0%, hsl(160, 60%, 88%) 100%)');
            return `<div class="hr-course-card">
                <div class="hr-course-card-header" style="background: ${bgHeader}">
                    <div class="hr-course-card-icon-wrap">${isOwned ? '🏠' : '📖'}</div>
                    <div class="hr-course-card-badges">
                        <span class="badge ${isOwned ? 'badge-info' : 'badge-gray'}">${isOwned ? 'Tự sở hữu' : 'Được giao'}</span>
                        ${isMandatory ? '<span class="badge badge-orange">Bắt buộc</span>' : ''}
                        <span class="badge badge-purple">${c.status || 'Draft'}</span>
                    </div>
                </div>
                <div class="hr-course-card-body">
                    <h4 class="hr-course-card-title" title="${c.title}">${c.title}</h4>
                    <div class="hr-course-card-stats">
                        <div class="hr-course-stat-item">
                            <span class="hr-course-stat-val">${c.moduleCount || 0}</span>
                            <span>Chương</span>
                        </div>
                        <div class="hr-course-stat-item">
                            <span class="hr-course-stat-val">${c.lessonCount || 0}</span>
                            <span>Bài học</span>
                        </div>
                        <div class="hr-course-stat-item">
                            <span class="hr-course-stat-val">${c.examCount || 0}</span>
                            <span>Quiz</span>
                        </div>
                    </div>
                </div>
                <div class="hr-course-card-footer">
                    ${isOwned ? `<button class="btn btn-sm btn-secondary" onclick="openCourseContentModal(${c.courseId})">🧩 Nội dung</button>` : ''}
                    <button class="btn btn-sm btn-secondary" onclick="openAssignDeptModal(${c.courseId})">${isTrainingCenter ? '📢 Phân phòng' : '📢 Giao phòng'}</button>
                    <button class="btn btn-sm btn-primary" onclick="openAssignModal(${c.courseId})">🎯 Cá nhân</button>
                </div>
            </div>`;
        }).join('');
    } catch(e) {}
}

async function loadAssignmentsData() {
    try {
        const res = await apiFetch('/api/hr/assignments');
        const list = res.assignments || [];
        const container = document.getElementById('assignmentListContainer');
        if(!container) return;
        if(list.length===0){ container.innerHTML='<div style="text-align:center;padding:40px;color:var(--text-secondary);">Chưa có phân công nào.</div>'; return; }
        container.innerHTML = list.map(a=>{
            const col = avatarColor(a.employeeName||'A');
            const priorityClass = a.priority==='High'?'priority-high':a.priority==='Low'?'priority-low':'priority-normal';
            const due = a.dueDate ? new Date(a.dueDate) : null;
            const isOverdue = due && due < new Date() ? 'color:#ef4444;' : '';
            return `<div class="assign-item">
                <div class="assign-avatar-sm" style="background:${col};">${(a.employeeName||'?').charAt(0)}</div>
                <div class="assign-info">
                    <div class="assign-name">${a.employeeName} <span class="${priorityClass}" style="margin-left:6px;">${a.priority}</span></div>
                    <div class="assign-course">📚 ${a.courseName}</div>
                </div>
                <div style="text-align:right;font-size:12px;">
                    <div style="color:var(--text-secondary);">Giao bởi: ${a.assignedBy||'—'}</div>
                    <div style="${isOverdue}margin-top:3px;">${due?due.toLocaleDateString('vi-VN'):''}</div>
                </div>
            </div>`;
        }).join('');
    } catch(e) {}
}

// ===== MODALS =====
function openCreateCourseModal() { openModal('createCourseModal'); }
function openAssignDeptModal(courseId=null) {
    if(courseId) document.getElementById('assignDeptCourse').value = courseId;
    else document.getElementById('assignDeptCourse').value = '';
    openModal('assignDeptModal');
}
function openAssignModal(courseId=null, userId=null) {
    if(courseId) document.getElementById('assignCourse').value = courseId;
    if(userId) document.getElementById('assignEmployee').value = userId;
    openModal('assignModal');
}

async function submitCreateCourse() {
    const body = { title: document.getElementById('newCourseTitle').value, description: document.getElementById('newCourseDescription').value, isMandatory: document.getElementById('newCourseMandatory').checked };
    if(!body.title) return showToast('Vui lòng nhập tên khóa học','warning');
    await apiFetch('/api/hr/courses',{method:'POST',body:JSON.stringify(body)});
    showToast('Tạo khóa học thành công!','success'); closeModal('createCourseModal'); loadCourses();
}

async function submitCreateFullCourseAI() {
    const prompt = document.getElementById('aiPrompt').value || document.getElementById('newCourseTitle').value;
    if(!prompt) return showToast('Vui lòng nhập chủ đề để AI tạo khóa học đầy đủ','warning');
    try {
        const res = await apiFetch('/api/hr/ai-create-full-course',{method:'POST',body:JSON.stringify({prompt})});
        showToast(`AI đã tạo xong "${res.title}" với ${res.modulesCreated} chương`,'success');
        closeModal('createCourseModal');
        await loadCourses();
    } catch(e) {
        showToast('Lỗi tạo khóa học đầy đủ: '+e.message,'error');
    }
}

async function submitCreateEmployee() {
    const body = { fullName: document.getElementById('newEmpName').value, employeeCode: document.getElementById('newEmpCode').value, email: document.getElementById('newEmpEmail').value };
    if(!body.fullName||!body.email||!body.employeeCode) return showToast('Vui lòng điền đủ thông tin','error');
    try {
        await apiFetch('/api/hr/employees',{method:'POST',body:JSON.stringify(body)});
        showToast('Thêm nhân sự thành công!','success'); closeModal('createEmployeeModal');
        ['newEmpName','newEmpCode','newEmpEmail'].forEach(id=>document.getElementById(id).value='');
        await loadEmployeesData(); loadOverview();
    } catch(e){ showToast('Lỗi: '+e.message,'error'); }
}

async function generateWithAI() {
    const prompt = document.getElementById('aiPrompt').value;
    if(!prompt) return showToast('Vui lòng nhập chủ đề!','warning');
    const btn = document.getElementById('btnGenerateAI');
    btn.innerHTML='✨ Đang tạo...'; btn.disabled=true;
    try {
        const res = await apiFetch('/api/hr/ai-generate-course',{method:'POST',body:JSON.stringify({prompt})});
        document.getElementById('newCourseTitle').value=res.title;
        document.getElementById('newCourseDescription').value=res.description;
        showToast('AI đã tạo nội dung thành công!','success');
    } catch(e){ showToast('Lỗi AI: '+e.message,'error'); }
    finally{ btn.innerHTML='⚡ Tạo'; btn.disabled=false; }
}

async function submitAssignDept() {
    const courseId = parseInt(document.getElementById('assignDeptCourse').value);
    if(!courseId) return showToast('Vui lòng chọn khóa học','warning');
    
    let departmentId = 0;
    if (isTrainingCenter) {
        const selectEl = document.getElementById('assignDeptSelect');
        if (selectEl) {
            departmentId = parseInt(selectEl.value);
            if (!departmentId) {
                return showToast('Vui lòng chọn phòng ban','warning');
            }
        }
    }
    
    const dueDate = document.getElementById('assignDeptDueDate').value;
    try {
        await apiFetch('/api/hr/assign-dept',{method:'POST',body:JSON.stringify({courseId,departmentId,dueDate:dueDate?new Date(dueDate).toISOString():null})});
        showToast('Đã giao toàn phòng thành công!','success'); 
        closeModal('assignDeptModal'); 
        loadOverview();
    } catch(e) {
        showToast('Lỗi: ' + e.message, 'error');
    }
}

async function submitAssignment() {
    const userId=parseInt(document.getElementById('assignEmployee').value), courseId=parseInt(document.getElementById('assignCourse').value);
    if(!userId||!courseId) return showToast('Vui lòng chọn đầy đủ','warning');
    const dueDate=document.getElementById('assignDueDate').value, priority=document.getElementById('assignPriority').value;
    await apiFetch('/api/hr/assignments',{method:'POST',body:JSON.stringify({userId,courseId,priority,dueDate:dueDate?new Date(dueDate).toISOString():null})});
    showToast('Giao khóa học thành công!','success'); closeModal('assignModal'); loadOverview(); loadAssignmentsData();
}

async function openCourseContentModal(courseId) {
    document.getElementById('hrContentCourseId').value = courseId;
    hrSelectedModuleId = null;
    openModal('courseContentModal');
    await loadHrCourseContent();
}

async function loadHrCourseContent() {
    const courseId = document.getElementById('hrContentCourseId').value;
    if(!courseId) return;
    hrCourseContent = await apiFetch(`/api/hr/courses/${courseId}/content`);
    document.getElementById('courseContentTitle').textContent = `Nội dung: ${hrCourseContent.title} (${hrCourseContent.status || 'Draft'})`;
    document.getElementById('hrModuleList').innerHTML = (hrCourseContent.modules || []).map(m => `
        <button class="btn btn-secondary btn-sm" style="justify-content:flex-start" onclick="selectHrModule(${m.moduleId})">${m.title} (${(m.lessons||[]).length} bài)</button>
    `).join('') || '<div style="font-size:12px;color:var(--text-secondary)">Chưa có chương nào</div>';
    document.getElementById('hrExamList').innerHTML = (hrCourseContent.exams || []).map(e => `
        <div style="padding:10px;border:1px solid var(--border-color);border-radius:8px;font-size:12px">${e.examTitle} • ${e.durationMinutes || 30} phút</div>
    `).join('') || '<div style="font-size:12px;color:var(--text-secondary)">Chưa có quiz nào</div>';
    document.getElementById('hrContentArea').innerHTML = '<div style="text-align:center;color:var(--text-secondary);padding:40px 0;">Chọn một chương để thêm bài học hoặc publish khóa học.</div>';
}

function selectHrModule(moduleId) {
    hrSelectedModuleId = moduleId;
    const module = (hrCourseContent?.modules || []).find(m => m.moduleId === moduleId);
    if(!module) return;
    document.getElementById('hrContentArea').innerHTML = `
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div>
                <div style="font-size:18px;font-weight:700">${module.title}</div>
                <div style="font-size:12px;color:var(--text-secondary)">${(module.lessons||[]).length} bài học</div>
            </div>
            <button class="btn btn-primary btn-sm" onclick="openHrLessonModal(${module.moduleId})">➕ Thêm bài học</button>
        </div>
        ${(module.lessons||[]).length ? module.lessons.map(l => `
            <div style="padding:12px;border:1px solid var(--border-color);border-radius:10px;margin-bottom:10px;">
                <div style="font-weight:600">${l.title}</div>
                <div style="font-size:12px;color:var(--text-secondary);margin-top:4px">${l.contentType || 'Document'}${l.videoUrl ? ' • Có video' : ''}</div>
                <div style="font-size:12px;color:#475569;margin-top:6px">${(l.contentBody || '').substring(0,180)}${l.contentBody && l.contentBody.length > 180 ? '...' : ''}</div>
            </div>
        `).join('') : '<div style="text-align:center;color:var(--text-secondary);padding:30px 0;">Chưa có bài học nào trong chương này.</div>'}
    `;
}

function openHrModuleModal() {
    document.getElementById('hrModuleTitle').value = '';
    openModal('hrModuleModal');
}

async function submitHrModule() {
    const courseId = document.getElementById('hrContentCourseId').value;
    const title = document.getElementById('hrModuleTitle').value.trim();
    if(!title) return showToast('Vui lòng nhập tên chương','warning');
    await apiFetch(`/api/hr/courses/${courseId}/modules`, { method:'POST', body: JSON.stringify({ title, sortOrder: (hrCourseContent?.modules || []).length }) });
    closeModal('hrModuleModal');
    showToast('Đã thêm chương học','success');
    await loadHrCourseContent();
}

function openHrLessonModal(moduleId) {
    document.getElementById('hrLessonModuleId').value = moduleId;
    document.getElementById('hrLessonTitle').value = '';
    document.getElementById('hrLessonType').value = 'Document';
    document.getElementById('hrLessonBody').value = '';
    document.getElementById('hrLessonVideo').value = '';
    openModal('hrLessonModal');
}

async function submitHrLesson() {
    const moduleId = document.getElementById('hrLessonModuleId').value;
    const body = {
        title: document.getElementById('hrLessonTitle').value.trim(),
        contentType: document.getElementById('hrLessonType').value,
        contentBody: document.getElementById('hrLessonBody').value,
        videoUrl: document.getElementById('hrLessonVideo').value,
        sortOrder: ((hrCourseContent?.modules || []).find(m => String(m.moduleId) === String(moduleId))?.lessons || []).length
    };
    if(!body.title) return showToast('Vui lòng nhập tên bài học','warning');
    await apiFetch(`/api/hr/modules/${moduleId}/lessons`, { method:'POST', body: JSON.stringify(body) });
    closeModal('hrLessonModal');
    showToast('Đã thêm bài học','success');
    await loadHrCourseContent();
    selectHrModule(parseInt(moduleId));
}

async function toggleHrPublish() {
    const courseId = document.getElementById('hrContentCourseId').value;
    if(!courseId || !hrCourseContent) return;
    const shouldPublish = (hrCourseContent.status || 'Draft') !== 'Published';
    await apiFetch(`/api/hr/courses/${courseId}/publish`, { method:'POST', body: JSON.stringify({ publish: shouldPublish }) });
    showToast(shouldPublish ? 'Khóa học đã publish cho student' : 'Khóa học đã chuyển về Draft', 'success');
    await loadHrCourseContent();
    await loadCourses();
}

// ===== EMPLOYEE PROFILE PANEL =====
function openAssignFromProfile() { closeProfilePanel(); openAssignModal(null, currentProfileId); }

async function openEmployeeProfile(id) {
    currentProfileId = id;
    document.getElementById('profileOverlay').style.display='block';
    document.getElementById('profileLoading').style.display='block';
    document.getElementById('profileContentBody').style.display='none';
    document.getElementById('prfName').textContent='Đang tải...';
    setTimeout(()=>{ document.getElementById('profilePanel').style.right='0'; },10);
    try {
        const res = await apiFetch(`/api/hr/employees/${id}/profile`);
        const col = avatarColor(res.fullName);
        document.getElementById('prfAvatar').style.background=`linear-gradient(135deg,${col},${AVATAR_COLORS[(AVATAR_COLORS.indexOf(col)+2)%AVATAR_COLORS.length]})`;
        document.getElementById('prfAvatar').textContent=res.fullName.charAt(0).toUpperCase();
        document.getElementById('prfName').textContent=res.fullName;
        document.getElementById('prfMeta').textContent=`${res.jobTitle} • ${res.departmentName}`;
        document.getElementById('prfEmail').textContent=res.email;
        document.getElementById('prfTags').innerHTML=[
            `<span class="profile-tag">🆔 ${res.employeeCode}</span>`,
            `<span class="profile-tag" style="background:${res.status==='Active'?'rgba(16,185,129,.2)':'rgba(239,68,68,.2)'};color:${res.status==='Active'?'#10b981':'#ef4444'};">${res.status==='Active'?'✅ Đang làm':'⛔ Vô hiệu'}</span>`
        ].join('');

        const completed = res.courses.filter(c=>c.status==='Completed').length;
        const inProg = res.courses.filter(c=>c.status==='InProgress').length;
        document.getElementById('prfStatStrip').innerHTML=`
            <div class="profile-stat-box"><div class="profile-stat-num" style="color:#3b82f6">${res.courses.length}</div><div class="profile-stat-lbl">Khóa đã giao</div></div>
            <div class="profile-stat-box"><div class="profile-stat-num" style="color:#10b981">${completed}</div><div class="profile-stat-lbl">Hoàn thành</div></div>
            <div class="profile-stat-box"><div class="profile-stat-num" style="color:#f59e0b">${inProg}</div><div class="profile-stat-lbl">Đang học</div></div>`;

        const prfToggle = document.getElementById('prfToggleStatusBtn');
        prfToggle.textContent = res.status==='Active'?'⛔ Vô hiệu hóa':'✅ Kích hoạt';
        prfToggle.onclick = () => toggleUserStatus(id, res.status==='Active'?'Inactive':'Active');

        const cEl=document.getElementById('prfCourses');
        cEl.innerHTML=res.courses.length===0?'<div style="text-align:center;color:var(--text-secondary);padding:20px;">Chưa được giao đào tạo</div>':
            res.courses.map(c=>{
                const pct=c.progress||0, pctColor=pct===100?'#10b981':pct>50?'#3b82f6':'#f59e0b';
                const statusLabel=c.status==='Completed'?'Hoàn thành':c.status==='InProgress'?'Đang học':'Chưa bắt đầu';
                return `<div class="course-row">
                    <div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:13px;">
                        <strong>${c.title}</strong>
                        <span style="color:${pctColor};font-weight:600;">${pct}%</span>
                    </div>
                    <div style="height:5px;background:var(--border-color);border-radius:3px;overflow:hidden;margin-bottom:5px;">
                        <div style="height:100%;background:${pctColor};width:${pct}%;"></div>
                    </div>
                    <div style="font-size:11px;color:var(--text-secondary);">${statusLabel}</div>
                </div>`;
            }).join('');

        const sEl=document.getElementById('prfSkills');
        sEl.innerHTML=res.skills.length===0?'<div style="text-align:center;color:var(--text-secondary);padding:20px;">Chưa có đánh giá kỹ năng</div>':
            res.skills.map(s=>`
                <div class="skill-bar-row">
                    <div class="skill-bar-label"><span>${s.skillName}</span><span style="font-weight:700;">${s.score}/100</span></div>
                    <div class="skill-bar-bg"><div class="skill-bar-fill" style="width:${s.score||0}%;"></div></div>
                </div>`).join('');

        document.getElementById('profileLoading').style.display='none';
        document.getElementById('profileContentBody').style.display='block';
    } catch(e) {
        document.getElementById('profileLoading').innerHTML=`<div style="color:#ef4444;text-align:center;">Lỗi tải hồ sơ: ${e.message}</div>`;
    }
}

function closeProfilePanel() {
    document.getElementById('profilePanel').style.right='-500px';
    setTimeout(()=>{ document.getElementById('profileOverlay').style.display='none'; currentProfileId=null; },350);
}

async function toggleUserStatus(id, newStatus) {
    if(!confirm(`Xác nhận ${newStatus==='Active'?'kích hoạt':'vô hiệu hóa'} nhân viên này?`)) return;
    await apiFetch(`/api/hr/employees/${id}/status`,{method:'PATCH',body:JSON.stringify(newStatus)});
    showToast('Cập nhật trạng thái thành công!','success');
    await loadEmployeesData(); closeProfilePanel();
}

function navigate(page) {
    document.querySelectorAll('.nav-link').forEach(link=>{
        link.classList.remove('active');
        const oc=link.getAttribute('onclick');
        if(oc&&oc.includes(`navigate('${page}')`)) link.classList.add('active');
        else if(page==='hr-overview'&&oc&&oc.includes('location.href')) link.classList.add('active');
    });
    const titles={
        'hr-overview':{t:'Tổng quan bộ phận',s:'Dashboard quản lý nhân sự và đào tạo'},
        'members':{t:'Nhân sự phòng ban',s:'Xem tiến độ & hồ sơ năng lực từng nhân viên'},
        'courses':{t:'Khóa học bộ phận',s:'Quản lý và phân công khóa học đào tạo'},
        'assignments':{t:'Phân công đào tạo',s:'Lịch sử giao nhiệm vụ học tập'},
        'staff-progress':{t:'Tiến độ nhân viên',s:'Theo dõi các bài quiz và bài học chưa hoàn thành'},
        'attendance':{t:'Quản lý điểm danh',s:'Kiểm soát chuyên cần các buổi offline'},
        'hr-notifications':{t:'Thông báo đề xuất',s:'Xem danh sách đề xuất xin gia hạn và phản hồi'},
        'exams':{t:'Quản lý bài thi & Đánh giá',s:'Theo dõi kết quả làm bài thi và thiết lập cấu trúc đề thi kéo thả'}
    };
    if(titles[page]){ document.getElementById('pageTitle').textContent=titles[page].t; document.getElementById('pageSubtitle').textContent=titles[page].s; }
    document.querySelectorAll('.page-section').forEach(s=>s.style.display=s.id===page?'':'none');
    if(page==='staff-progress') loadStaffProgress();
    if(page==='attendance') loadAttendanceEvents();
    if(page==='documents') loadDeptDocuments();
    if(page==='hr-notifications') loadHrNotifications();
    if(page==='exams') loadExamsPageData();
}

async function loadStaffProgress() {
    try {
        const data = await apiFetch('/api/hr/staff-progress');
        const tbody = document.getElementById('staffProgressTable');
        if (!tbody) return;
        
        tbody.innerHTML = data.map(u => `
            <tr>
                <td><strong>${u.fullName}</strong></td>
                <td>
                    ${u.incompleteQuizzes.length ? u.incompleteQuizzes.map(q => `<div class="badge badge-warning" style="margin-bottom:4px">${q.title}</div>`).join('') : '<span style="color:#10b981">Đã hoàn thành</span>'}
                </td>
                <td>
                    ${u.missingLessons.length ? u.missingLessons.map(l => `<div class="badge badge-blue" style="margin-bottom:4px">${l.title}</div>`).join('') : '<span style="color:#10b981">Đã hoàn thành</span>'}
                </td>
                <td>
                    <button class="btn btn-primary btn-sm" onclick="notifyStaff(${u.userId})">🔔 Nhắc nhở</button>
                </td>
            </tr>
        `).join('') || '<tr><td colspan="4" style="text-align:center">Chưa có dữ liệu.</td></tr>';
    } catch (e) {
        showToast(e.message, 'error');
    }
}

async function notifyStaff(userId) {
    const { value: text } = await Swal.fire({
        title: 'Gửi lời nhắc',
        input: 'textarea',
        inputLabel: 'Nội dung nhắc nhở',
        inputPlaceholder: 'Vui lòng hoàn thành các bài học còn thiếu...',
        showCancelButton: true
    });
    if (text) {
        try {
            await apiFetch('/api/hr/notify-staff', { method: 'POST', body: JSON.stringify({ userId, message: text }) });
            showToast('Đã gửi thông báo nhắc nhở.');
        } catch (e) { showToast(e.message, 'error'); }
    }
}

async function loadAttendanceEvents() {
    try {
        const schedules = await apiFetch('/api/hr/schedules');
        const select = document.getElementById('attendanceEventSelect');
        if (!select) return;
        
        if (!schedules || schedules.length === 0) {
            select.innerHTML = '<option value="">-- Chưa có lịch học nào --</option>';
            return;
        }
        
        select.innerHTML = '<option value="">-- Chọn sự kiện --</option>' + schedules.map(s => `
            <option value="${s.eventId}">${s.title} ${s.startTime ? '(' + fmtDateTime(s.startTime) + ')' : ''}</option>
        `).join('');
    } catch (e) {
