async function generateUploadQuizWithAI() {
    const prompt = document.getElementById('aiUploadNewQuizPrompt').value.trim();
    if (!prompt) { showToast('Vui lòng nhập yêu cầu cho AI!', 'warning'); return; }

    const statusEl = document.getElementById('aiUploadNewQuizStatus');
    const btn = document.getElementById('btnGenerateUploadNewQuizAI');

    statusEl.innerText = '⏳ AI đang thiết kế bộ câu hỏi...';
    btn.disabled = true;

    try {
        const result = await apiFetch('/api/hr/generate-quiz-ai', {
            method: 'POST',
            body: JSON.stringify({ prompt })
        });

        if (result && result.examTitle) {
            document.getElementById('uploadNewQuizTitle').value = result.examTitle;
            if (result.questions) {
                uploadQuizQuestions = result.questions.map((q, idx) => ({
                    id: Date.now() + idx,
                    questionText: q.questionText || q.QuestionText || '',
                    options: (q.options || []).map(opt => {
                        if (typeof opt === 'string') return { text: opt, isCorrect: false };
                        return {
                            text: opt.optionText || opt.OptionText || '',
                            isCorrect: opt.isCorrect !== undefined ? opt.isCorrect : (opt.IsCorrect || false)
                        };
                    })
                }));
                renderUploadQuizQuestions();
                statusEl.innerText = `✅ Đã soạn ${uploadQuizQuestions.length} câu hỏi.`;
                showToast('AI đã soạn thảo xong!');
            }
        }
    } catch (e) {
        statusEl.innerText = '❌ Lỗi: ' + e.message;
        showToast('Lỗi AI: ' + e.message, 'error');
    } finally {
        btn.disabled = false;
    }
}

async function generateUploadQuizFromFile() {
    const fileInput = document.getElementById('uploadNewQuizFileAI');
    const statusEl = document.getElementById('aiUploadNewQuizStatus');
    
    if (!fileInput.files || fileInput.files.length === 0) {
        showToast('Vui lòng chọn file document (PDF, Docx, TXT...)', 'warning');
        return;
    }

    const file = fileInput.files[0];
    statusEl.innerText = '⏳ Đang đọc file và trích xuất câu hỏi...';
    statusEl.style.color = '#f59e0b';

    try {
        const base64Full = await new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => resolve(reader.result);
            reader.onerror = reject;
            reader.readAsDataURL(file);
        });
        
        const pureBase64 = base64Full.split(',')[1];
        
        const result = await apiFetch('/api/hr/generate-quiz-from-file', {
            method: 'POST',
            body: JSON.stringify({
                base64Data: pureBase64,
                mimeType: file.type || 'application/pdf'
            })
        });

        if (result && result.questions) {
            uploadQuizQuestions = result.questions.map((q, idx) => ({
                id: Date.now() + idx,
                questionText: q.questionText || q.QuestionText || '',
                options: (q.options || []).map(opt => {
                    if (typeof opt === 'string') return { text: opt, isCorrect: false };
                    return {
                        text: opt.optionText || opt.OptionText || '',
                        isCorrect: opt.isCorrect !== undefined ? opt.isCorrect : (opt.IsCorrect || false)
                    };
                })
            }));
            renderUploadQuizQuestions();
            statusEl.innerText = `✅ Đã trích xuất ${uploadQuizQuestions.length} câu hỏi thành công!`;
            statusEl.style.color = '#10b981';
            showToast('Đã trích xuất câu hỏi từ file!');
        }
    } catch (e) {
        statusEl.innerText = '❌ Lỗi: ' + e.message;
        statusEl.style.color = '#ef4444';
        showToast(e.message, 'error');
    }
}

function addUploadQuizQuestion() {
    const q = {
        id: Date.now(),
        questionText: '',
        options: [
            { text: '', isCorrect: true },
            { text: '', isCorrect: false }
        ]
    };
    uploadQuizQuestions.push(q);
    renderUploadQuizQuestions();
}

function removeUploadQuizQuestion(id) {
    uploadQuizQuestions = uploadQuizQuestions.filter(q => q.id !== id);
    renderUploadQuizQuestions();
}

function addUploadQuizOption(qId) {
    const q = uploadQuizQuestions.find(q => q.id === qId);
    if (q) {
        q.options.push({ text: '', isCorrect: false });
        renderUploadQuizQuestions();
    }
}

function renderUploadQuizQuestions() {
    const container = document.getElementById('uploadQuizQuestionsContainer');
    if (!container) return;
    
    if (uploadQuizQuestions.length === 0) {
        container.innerHTML = '<div style="text-align:center; padding:20px; border:1px dashed #cbd5e1; border-radius:8px; color:#64748b; font-size:13px;">Chưa có câu hỏi nào.</div>';
        return;
    }
    
    container.innerHTML = uploadQuizQuestions.map((q, idx) => `
        <div style="padding:16px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; position:relative;">
            <button type="button" onclick="removeUploadQuizQuestion(${q.id})" style="position:absolute; top:10px; right:10px; background:none; border:none; color:#ef4444; cursor:pointer;">✕</button>
            <div class="form-group" style="margin-bottom:12px;">
                <label class="form-label" style="font-size:12px;">Câu hỏi ${idx + 1}</label>
                <input type="text" class="form-input q-text" data-id="${q.id}" value="${libraryEscape(q.questionText)}" placeholder="Nhập câu hỏi..." onchange="updateUploadQuizQText(${q.id}, this.value)">
            </div>
            <div style="display:flex; flex-direction:column; gap:8px;">
                ${q.options.map((opt, oIdx) => `
                    <div style="display:flex; align-items:center; gap:8px;">
                        <input type="radio" name="correct_${q.id}" ${opt.isCorrect ? 'checked' : ''} onchange="updateUploadQuizCorrect(${q.id}, ${oIdx})">
                        <input type="text" class="form-input form-input-sm" style="flex:1;" value="${libraryEscape(opt.text)}" placeholder="Đáp án ${oIdx + 1}" onchange="updateUploadQuizOptText(${q.id}, ${oIdx}, this.value)">
                    </div>
                `).join('')}
                <button type="button" class="btn btn-sm" style="background:none; border:1px dashed #cbd5e1; color:#64748b; margin-top:4px;" onclick="addUploadQuizOption(${q.id})">+ Thêm đáp án</button>
            </div>
        </div>
    `).join('');
}

function updateUploadQuizQText(id, val) { const q = uploadQuizQuestions.find(q => q.id === id); if(q) q.questionText = val; }
function updateUploadQuizOptText(qId, oIdx, val) { const q = uploadQuizQuestions.find(q => q.id === qId); if(q) q.options[oIdx].text = val; }
function updateUploadQuizCorrect(qId, oIdx) {
    const q = uploadQuizQuestions.find(q => q.id === qId);
    if(q) q.options.forEach((opt, idx) => opt.isCorrect = (idx === oIdx));
}

async function submitUploadDocAndCreate() {
    const courseId = parseInt(document.getElementById('uploadDocCourse').value) || 0;
    const type = document.querySelector('input[name="uploadDocType"]:checked').value;

    if (!courseId) {
        showToast('Vui lòng chọn khóa học liên kết.', 'warning');
        return;
    }

    let title = '';
    let filePath = null;
    let pendingData = null;
    let newModuleName = null, newLessonName = null, newExamName = null;
    let moduleId = null;

    if (type === 'module') {
        newModuleName = document.getElementById('uploadNewModuleTitle').value.trim();
        if (!newModuleName) {
            showToast('Vui lòng nhập tên chương học.', 'warning');
            return;
        }
        title = newModuleName;
        pendingData = JSON.stringify({
            title: newModuleName,
            level: parseInt(document.getElementById('uploadNewModuleLevel').value) || 1
        });
    } else if (type === 'lesson') {
        newLessonName = document.getElementById('uploadNewLessonTitle').value.trim();
        if (!newLessonName) {
            showToast('Vui lòng nhập tên bài học.', 'warning');
            return;
        }
        title = newLessonName;
        moduleId = parseInt(document.getElementById('uploadNewLessonModule').value) || null;
        newModuleName = document.getElementById('uploadNewLessonNewModule').value.trim() || null;
        
        if (!moduleId && !newModuleName) {
            showToast('Vui lòng chọn chương hoặc nhập tên chương mới.', 'warning');
            return;
        }

        // Tải Video bài học hoặc lấy Link video Youtube
        const isVideo = document.getElementById('uploadNewLessonType').value === 'Video';
        let videoUrl = '';
        if (isVideo) {
            const uploadedVideo = await uploadTempFileHelper('uploadNewLessonVideoFileInput');
            const linkVideo = document.getElementById('uploadNewLessonVideo').value.trim();
            videoUrl = uploadedVideo || linkVideo || '';
        }

        // Tải file đính kèm hoặc lấy Link tài liệu
        const uploadedDoc = await uploadTempFileHelper('uploadNewLessonDocFileInput');
        const linkDoc = document.getElementById('uploadNewLessonFilePath').value.trim();
        filePath = uploadedDoc || linkDoc || null;
        
        pendingData = JSON.stringify({
            title: newLessonName,
            moduleId: moduleId,
            newModuleName: newModuleName,
            contentType: isVideo ? 'Video' : 'Document',
            contentBody: document.getElementById('uploadNewLessonBody').value.trim(),
            videoUrl: videoUrl,
            level: parseInt(document.getElementById('uploadNewLessonLevel').value) || 1
        });
    } else if (type === 'quiz') {
        newExamName = document.getElementById('uploadNewQuizTitle').value.trim();
        if (!newExamName) {
            showToast('Vui lòng nhập tiêu đề Quiz.', 'warning');
            return;
        }
        title = newExamName;
        if (uploadQuizQuestions.length === 0) {
            showToast('Vui lòng thêm ít nhất một câu hỏi cho Quiz.', 'warning');
            return;
        }
        
        pendingData = JSON.stringify({
            examTitle: newExamName,
            durationMinutes: parseInt(document.getElementById('uploadNewQuizDuration').value) || 30,
            passScore: parseInt(document.getElementById('uploadNewQuizPass').value) || 50,
            maxAttempts: parseInt(document.getElementById('uploadNewQuizMax').value) || null,
            level: parseInt(document.getElementById('uploadNewQuizLevel').value) || 1,
            startTime: document.getElementById('uploadNewQuizStartTime').value || null,
            endTime: document.getElementById('uploadNewQuizEndTime').value || null,
            questions: uploadQuizQuestions.map(q => ({
                questionText: q.questionText,
                questionType: 'MultipleChoice',
                options: q.options.map(opt => ({ optionText: opt.text, isCorrect: opt.isCorrect }))
            }))
        });
    }

    try {
        await apiFetch('/api/hr/documents', {
            method: 'POST',
            body: JSON.stringify({ 
                title, 
                filePath, 
                courseId, 
                moduleId,
                newModuleName,
                newLessonName,
                newExamName,
                targetType: type,
                pendingData
            })
        });
        closeModal('uploadDocModal');
        showToast('Đã gửi yêu cầu tạo nội dung, vui lòng chờ Admin phê duyệt.', 'success');
        loadDeptDocuments();
    } catch (e) {
        showToast(e.message, 'error');
    }
}
// End of upload document handlers

// ======= HR NOTIFICATIONS FUNCTIONS =======
async function loadHrNotifications() {
    try {
        const data = await apiFetch('/api/hr/notifications');
        const tbody = document.getElementById('hrNotificationsTable');
        if (!tbody) return;
        
        if (!data || data.length === 0) {
            tbody.innerHTML = `<tr><td colspan="3" style="text-align:center; padding:40px; color:#64748b;">Không có thông báo nào.</td></tr>`;
            return;
        }
        
        tbody.innerHTML = data.map(n => {
            const isRead = n.isRead;
            const titleStr = n.title || '';
            const matchExtend = titleStr.match(/^\[GIA HẠN - ID:(\d+)\]\s*(.*)$/);
            const matchProposal = titleStr.match(/^\[ĐỀ XUẤT - ID:(\d+)\]\s*(.*)$/);
            const matchReject = titleStr.match(/^\[TỪ CHỐI - ID:(\d+)\]\s*(.*)$/);
            
            let displayTitle = titleStr;
            let actionBtnHtml = '';
            let badgeHtml = '';
            let hideMarkAsRead = false;
            
            if (matchExtend) {
                const assignmentId = parseInt(matchExtend[1]);
                const cleanTitle = matchExtend[2];
                displayTitle = cleanTitle;
                badgeHtml = '<span class="badge badge-danger" style="background-color: #ef4444; color: white; padding: 2px 6px; border-radius: 4px; font-size: 11px;">GIA HẠN</span>';
                
                actionBtnHtml = `
                    <button class="btn btn-primary btn-sm" data-title="${escapeHtml(cleanTitle)}" onclick="quickExtend(this, ${assignmentId})">Gia hạn</button>
                `;
            } else if (matchProposal) {
                const docId = parseInt(matchProposal[1]);
                const cleanTitle = matchProposal[2];
                displayTitle = cleanTitle;
                badgeHtml = '<span class="badge badge-primary" style="background-color: #3b82f6; color: white; padding: 2px 6px; border-radius: 4px; font-size: 11px;">ĐỀ XUẤT</span>';
                hideMarkAsRead = true;
                
                if (!isRead) {
                    actionBtnHtml = `
                        <button class="btn btn-secondary btn-sm" onclick="openApprovalDetail(${docId}, ${n.id})">Xem chi tiết</button>
                        <button class="btn btn-success btn-sm" style="background-color:#10b981; color:white; border:none;" onclick="approveProposalDirect(${docId}, ${n.id})">Xác nhận</button>
                        <button class="btn btn-danger btn-sm" style="background-color:#ef4444; color:white; border:none;" onclick="rejectProposalDirect(${docId}, ${n.id})">Từ chối</button>
                    `;
                } else {
                    actionBtnHtml = `
                        <button class="btn btn-secondary btn-sm" onclick="openApprovalDetail(${docId})">Xem chi tiết</button>
                    `;
                }
            } else if (matchReject) {
                const docId = parseInt(matchReject[1]);
                const cleanTitle = matchReject[2];
                displayTitle = cleanTitle;
                badgeHtml = '<span class="badge badge-danger" style="background-color: #ef4444; color: white; padding: 2px 6px; border-radius: 4px; font-size: 11px;">TỪ CHỐI</span>';
                
                actionBtnHtml = `
                    <button class="btn btn-danger btn-sm" style="background-color:#ef4444; color:white; border:none;" onclick="showRejectionReason(${docId})">Xem lý do từ chối</button>
                `;
            }
            
            return `
                <tr style="${isRead ? 'opacity: 0.7;' : 'font-weight: 600;'}">
                    <td>
                        <div style="font-size:14px; color:var(--text-primary); margin-bottom:4px; display: flex; align-items: center; gap: 8px;">
                            ${badgeHtml} 
                            <span>${escapeHtml(displayTitle)}</span>
                        </div>
                    </td>
                    <td>
                        ${isRead ? '<span class="badge badge-success" style="background-color: #10b981; color: white; padding: 2px 6px; border-radius: 4px; font-size: 11px;">Đã đọc</span>' : '<span class="badge badge-warning" style="background-color: #f59e0b; color: white; padding: 2px 6px; border-radius: 4px; font-size: 11px;">Chưa đọc</span>'}
                    </td>
                    <td style="text-align:center;">
                        <div style="display:flex; gap:6px; justify-content:center;">
                            ${actionBtnHtml}
                            ${(!isRead && !hideMarkAsRead) ? `<button class="btn btn-secondary btn-sm" onclick="markHrNotifRead(${n.id})">Đã đọc</button>` : ''}
                        </div>
                    </td>
                </tr>
            `;
        }).join('');
    } catch (e) {
        showToast('Lỗi khi tải thông báo: ' + e.message, 'danger');
    }
}

async function quickExtend(btnEl, assignmentId) {
    const details = btnEl.getAttribute('data-title') || '';
    const courseMatch = details.match(/xin gia hạn\s+['"](.*?)['"]/);
    const courseTitle = courseMatch ? courseMatch[1] : 'Khóa học';
    await extendAssignment(assignmentId, courseTitle);
    await loadHrNotifications();
}

async function markHrNotifRead(id) {
    try {
        await apiFetch(`/api/hr/notifications/${id}/read`, { method: 'POST' });
        showToast('Đã đánh dấu đã đọc', 'success');
        await loadHrNotifications();
    } catch (e) {
        showToast('Lỗi: ' + e.message, 'danger');
    }
}

async function markAllHrNotificationsRead() {
    try {
        await apiFetch(`/api/hr/notifications/read-all`, { method: 'POST' });
        showToast('Đã đánh dấu đọc tất cả', 'success');
        await loadHrNotifications();
    } catch (e) {
        showToast('Lỗi: ' + e.message, 'danger');
    }
}

