async function extendAssignment(target, titleOrId) {
    let assignmentId;
    let title;
    
    if (typeof target === 'object' && target !== null && target.nodeType) {
        assignmentId = titleOrId;
        title = target.getAttribute('data-title') || 'Khóa học';
    } else {
        assignmentId = target;
        title = titleOrId || 'Khóa học';
    }
    
    if (!assignmentId) {
        showToast('Không tìm thấy phân công để gia hạn.', 'danger');
        return;
    }
    
    const now = new Date();
    
    const result = await Swal.fire({
        title: 'Gia hạn khóa học',
        html: `
            <div style="text-align: left; font-size: 14px; font-family: sans-serif; line-height: 1.5;">
                <p style="margin-bottom: 16px; color: #475569;">Gia hạn học tập cho khóa: <br/><strong style="color: #1e293b; font-size: 15px;">${title}</strong></p>
                
                <div style="background: #f8fafc; padding: 14px; border-radius: 8px; border: 1px solid #e2e8f0; margin-bottom: 16px;">
                    <div style="margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between;">
                        <label style="cursor:pointer; display:flex; align-items:center; gap:8px; font-weight:600; color: #334155;">
                            <input type="radio" name="extendUnit" value="days" checked id="unitDays" style="width: 16px; height: 16px; margin: 0; cursor: pointer;"> Gia hạn theo ngày
                        </label>
                        <div style="display: flex; align-items: center; gap: 6px;">
                            <input type="number" id="extendDaysInput" class="swal2-input" style="width: 80px; height: 36px; margin: 0; padding: 4px 8px; text-align: center; border-radius: 6px; border: 1px solid #cbd5e1;" min="1" max="3" value="1">
                            <span style="color: #64748b; font-weight: 500; font-size: 13px;">ngày</span>
                        </div>
                    </div>
                    
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <label style="cursor:pointer; display:flex; align-items:center; gap:8px; font-weight:600; color: #334155;">
                            <input type="radio" name="extendUnit" value="hours" id="unitHours" style="width: 16px; height: 16px; margin: 0; cursor: pointer;"> Gia hạn theo giờ
                        </label>
                        <div style="display: flex; align-items: center; gap: 6px;">
                            <input type="number" id="extendHoursInput" class="swal2-input" style="width: 80px; height: 36px; margin: 0; padding: 4px 8px; text-align: center; border-radius: 6px; border: 1px solid #cbd5e1; background-color: #f1f5f9;" min="1" max="72" value="24" disabled>
                            <span style="color: #64748b; font-weight: 500; font-size: 13px;">giờ</span>
                        </div>
                    </div>
                </div>
                
                <div style="padding: 12px; background: rgba(16,185,129,0.08); border-radius: 8px; border: 1px solid rgba(16,185,129,0.2); font-size: 13px;">
                    📅 <strong>Hạn hoàn thành mới dự kiến:</strong><br/>
                    <span id="extendDatePreview" style="color: #10b981; font-weight: 800; font-size: 15px; display: block; margin-top: 4px;">--</span>
                </div>
            </div>
        `,
        showCancelButton: true,
        confirmButtonText: 'Xác nhận gia hạn',
        cancelButtonText: 'Hủy',
        focusConfirm: false,
        didOpen: () => {
            const unitDays = document.getElementById('unitDays');
            const unitHours = document.getElementById('unitHours');
            const daysInput = document.getElementById('extendDaysInput');
            const hoursInput = document.getElementById('extendHoursInput');
            const preview = document.getElementById('extendDatePreview');
            
            const update = () => {
                const isDays = unitDays.checked;
                
                if (isDays) {
                    daysInput.disabled = false;
                    daysInput.style.backgroundColor = '#ffffff';
                    hoursInput.disabled = true;
                    hoursInput.style.backgroundColor = '#f1f5f9';
                    
                    const val = parseInt(daysInput.value) || 0;
                    if (val > 3) daysInput.value = 3;
                    if (val < 1 && daysInput.value !== '') daysInput.value = 1;
                } else {
                    daysInput.disabled = true;
                    daysInput.style.backgroundColor = '#f1f5f9';
                    hoursInput.disabled = false;
                    hoursInput.style.backgroundColor = '#ffffff';
                    
                    const val = parseInt(hoursInput.value) || 0;
                    if (val > 72) hoursInput.value = 72;
                    if (val < 1 && hoursInput.value !== '') hoursInput.value = 1;
                }
                
                const activeVal = isDays ? (parseInt(daysInput.value) || 0) : (parseInt(hoursInput.value) || 0);
                if (activeVal <= 0) {
                    preview.textContent = '--';
                    return;
                }
                
                const newDate = new Date(now.getTime());
                if (isDays) {
                    newDate.setDate(newDate.getDate() + activeVal);
                } else {
                    newDate.setHours(newDate.getHours() + activeVal);
                }
                
                preview.textContent = fmtDateTime(newDate);
            };
            
            daysInput.addEventListener('input', update);
            hoursInput.addEventListener('input', update);
            unitDays.addEventListener('change', update);
            unitHours.addEventListener('change', update);
            update();
        },
        preConfirm: () => {
            const unitDays = document.getElementById('unitDays');
            const isDays = unitDays.checked;
            const daysInput = document.getElementById('extendDaysInput');
            const hoursInput = document.getElementById('extendHoursInput');
            
            const val = isDays ? (parseInt(daysInput.value) || 0) : (parseInt(hoursInput.value) || 0);
            
            if (val <= 0) {
                Swal.showValidationMessage('Vui lòng nhập giá trị lớn hơn 0!');
                return false;
            }
            if (isDays && val > 3) {
                Swal.showValidationMessage('Gia hạn theo ngày không được vượt quá 3 ngày!');
                return false;
            }
            if (!isDays && val > 72) {
                Swal.showValidationMessage('Gia hạn theo giờ không được vượt quá 72 giờ!');
                return false;
            }
            
            const targetDate = new Date(now.getTime());
            if (isDays) {
                targetDate.setDate(targetDate.getDate() + val);
            } else {
                targetDate.setHours(targetDate.getHours() + val);
            }
            return targetDate;
        }
    });
    
    if (result.isConfirmed && result.value) {
        try {
            const newDueDate = result.value.toISOString();
            await apiFetch(`/api/hr/assignments/${assignmentId}/extend`, {
                method: 'POST',
                body: JSON.stringify({ newDueDate })
            });
            showToast('Gia hạn khóa học thành công!', 'success');
            if (typeof loadStaffProgress === 'function') await loadStaffProgress();
            if (typeof loadHrNotifications === 'function') await loadHrNotifications();
        } catch (e) {
            showToast('Lỗi khi gia hạn: ' + e.message, 'danger');
        }
    }
}

