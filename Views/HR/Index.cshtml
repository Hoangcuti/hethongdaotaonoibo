function navigate(page) {
    document.querySelectorAll('.nav-link').forEach(link=>{
        link.classList.remove('active');
        const oc=link.getAttribute('onclick');
        if(oc&&oc.includes(`navigate('${page}')`)) link.classList.add('active');
        else if(page==='hr-overview'&&oc&&oc.includes('location.href')) link.classList.add('active');
    });
    const titles={'hr-overview':{t:'Tổng quan bộ phận',s:'Dashboard quản lý nhân sự và đào tạo'},'members':{t:'Nhân sự phòng ban',s:'Xem tiến độ & hồ sơ năng lực từng nhân viên'},'courses':{t:'Khóa học bộ phận',s:'Quản lý và phân công khóa học đào tạo'},'exams':{t:'Quản lý bài kiểm tra & Đánh giá',s:'Thống kê kết quả thi & Thiết lập cấu trúc đề thi kéo thả.'},'assignments':{t:'Phân công đào tạo',s:'Lịch sử giao nhiệm vụ học tập'},'staff-progress':{t:'Tiến độ nhân viên',s:'Theo dõi các bài quiz và bài học chưa hoàn thành'},'attendance':{t:'Quản lý điểm danh',s:'Kiểm soát chuyên cần các buổi offline'},'hr-notifications':{t:'Thông báo đề xuất',s:'Danh sách yêu cầu xin gia hạn và thông báo từ nhân viên'},'approvals':{t:'Phê duyệt tài liệu',s:'Xem xét và phê duyệt các tài liệu, chương, bài học, quiz do giảng viên gửi lên'}};
    if(titles[page]){ document.getElementById('pageTitle').textContent=titles[page].t; document.getElementById('pageSubtitle').textContent=titles[page].s; }
    document.querySelectorAll('.page-section').forEach(s=>s.style.display=s.id===page?'':'none');
    if(page==='staff-progress') loadStaffProgress();
    if(page==='attendance') loadAttendanceEvents();
    if(page==='documents') loadDocumentLibrary();
    if(page==='hr-notifications') loadHrNotifications();
    if(page==='exams') loadExamsPageList();
    if(page==='approvals') loadApprovals();
}

