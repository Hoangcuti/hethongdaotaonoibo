async function extendAssignment(assignmentId, title) {
    if (!assignmentId) {
        showToast('Không tìm thấy phân công để gia hạn.', 'danger');
        return;
    }
    const { value: datetime } = await Swal.fire({
        title: 'Gia hạn phân công',
        html: `Chọn ngày giờ hết hạn mới cho: <br/><strong>${title}</strong>`,
        input: 'datetime-local',
        showCancelButton: true,
        confirmButtonText: 'Gia hạn ngay',
        cancelButtonText: 'Hủy',
        inputValidator: (value) => {
            if (!value) {
                return 'Bạn phải chọn ngày giờ gia hạn!';
            }
        }
    });
    
    if (datetime) {
        try {
            const newDueDate = new Date(datetime).toISOString();
            await apiFetch(`/api/hr/assignments/${assignmentId}/extend`, {
                method: 'POST',
                body: JSON.stringify({ newDueDate })
            });
            showToast('Gia hạn khóa học thành công!', 'success');
            await loadStaffProgress();
        } catch (e) {
            showToast('Lỗi khi gia hạn: ' + e.message, 'danger');
        }
    }
}

