    document.getElementById('uploadNewQuizStartTime').value = '';
    document.getElementById('uploadNewQuizEndTime').value = '';
    document.getElementById('aiUploadNewQuizPrompt').value = '';
    document.getElementById('uploadNewQuizFileAI').value = '';
    document.getElementById('aiUploadNewQuizStatus').innerText = '';
    
